{% extends "layout.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block pageTitle %}{% if errors.length %}Error: {% endif %}Tell us about your disability and how it affects your housing needs{% endblock %}

{% block content %}
{{ govukBackLink({ text: "Back", href: "/apply-housing-benefit/details" }) }}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    {% if errors.length %}
      {{ govukErrorSummary({ titleText: "There is a problem", errorList: errors }) }}
    {% endif %}
    <form method="post" action="/apply-housing-benefit/disability-details" novalidate>
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      {{ govukCharacterCount({
        id: "disabilityDetails",
        name: "disabilityDetails",
        maxlength: 1000,
        value: values.disabilityDetails,
        label: {
          text: "Tell us about your disability and how it affects your housing needs",
          isPageHeading: true,
          classes: "govuk-label--xl"
        },
        errorMessage: { text: fieldErrors.disabilityDetails } if fieldErrors.disabilityDetails else undefined
      }) }}
      {{ govukButton({ text: "Continue" }) }}
    </form>
  </div>
</div>
{% endblock %}
