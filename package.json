{
  "name": "ai-gov-frontend-express",
  "version": "0.1.0",
  "private": true,
  "description": "GOV.UK Design System registration service built with Express",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "commonjs",
  "scripts": {
    "prestart": "npm run build:assets",
    "start": "node server.js",
    "predev": "npm run build:assets",
    "dev": "nodemon server.js",
    "build:assets": "node scripts/build-assets.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build:assets && jest",
    "test:watch": "jest --watch",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down"
  },
  "dependencies": {
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^6.3.0",
    "helmet": "^8.2.0",
    "nunjucks": "^3.2.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jsdom": "^26.1.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "pg-mem": "^3.0.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "sass": "^1.101.0",
    "supertest": "^7.2.2"
  }
}
