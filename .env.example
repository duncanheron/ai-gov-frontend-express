PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string
DATABASE_URL=postgresql://app:app@localhost:5432/app

# Optional - required for the AI-assisted service picker (/choose-service) to return real
# recommendations. A VERCEL_OIDC_TOKEN (from `vercel env pull`) also works as an alternative.
AI_GATEWAY_API_KEY=
